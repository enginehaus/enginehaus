{
  "name": "enginehaus",
  "version": "0.1.0",
  "description": "Give your AI agents memory that persists. Coordination, context, and quality gates for AI-assisted development.",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "enginehaus": "build/bin/enginehaus.js",
    "eh": "build/bin/enginehaus.js",
    "enginehaus-mcp": "build/index.js"
  },
  "scripts": {
    "build": "eslint src/ && tsc && cp src/profiles/*.json build/profiles/ && chmod +x build/index.js && chmod +x build/bin/enginehaus.js",
    "watch": "tsc --watch",
    "prepare": "npm run build",
    "postinstall": "test -n \"$CI\" || npm link --silent 2>/dev/null || true",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "validate-ci": "node build/bin/enginehaus.js validate --format github",
    "setup": "npm run build && node build/bin/enginehaus.js setup",
    "serve:http": "node build/index.js --transport=http",
    "serve:http:auth": "MCP_AUTH_MODE=api-key node build/index.js --transport=http",
    "quality": "enginehaus ci validate --format json",
    "quality:ci": "enginehaus ci validate --format github-annotations --fail-on-critical",
    "tunnel": "./scripts/tunnel.sh"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "coordination",
    "ai",
    "ai-coding",
    "workflow",
    "task-management",
    "claude",
    "anthropic",
    "multi-agent",
    "sqlite",
    "cli"
  ],
  "author": "Trevor Wingert",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enginehaus/enginehaus.git"
  },
  "bugs": {
    "url": "https://github.com/enginehaus/enginehaus/issues"
  },
  "homepage": "https://enginehaus.dev",
  "files": [
    "build/**/*.js",
    "build/**/*.d.ts",
    "src/hooks",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "better-sqlite3": "^11.10.0",
    "commander": "^13.1.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "jose": "^6.1.3",
    "simple-git": "^3.25.0",
    "uuid": "^10.0.0",
    "ws": "^8.19.0"
  },
  "optionalDependencies": {
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.15.6",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.53.1",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  }
}
