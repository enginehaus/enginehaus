# Enginehaus MCP Server Environment Configuration
# Copy to .env and customize for your deployment

# =============================================================================
# MCP HTTP Transport
# =============================================================================

# Port for HTTP server (default: 3000)
MCP_PORT=3000

# CORS allowed origins (default: * for all)
# For production, restrict to specific domains
MCP_CORS_ORIGINS=*

# =============================================================================
# Authentication
# =============================================================================

# Auth mode: none, api-key, oauth (default: none)
MCP_AUTH_MODE=api-key

# For api-key mode: comma-separated list of valid API keys
# Generate a key: openssl rand -hex 32
MCP_API_KEYS=your-secret-api-key-here

# =============================================================================
# OAuth 2.1 Configuration (for oauth mode)
# =============================================================================

# OAuth issuer URL (e.g., Auth0, Okta, Cognito)
# MCP_OAUTH_ISSUER=https://your-tenant.auth0.com/

# Expected audience for token validation
# MCP_OAUTH_AUDIENCE=https://mcp.yourdomain.com

# JWKS URI for token signature verification
# MCP_OAUTH_JWKS_URI=https://your-tenant.auth0.com/.well-known/jwks.json

# Required scopes (comma-separated)
# MCP_OAUTH_SCOPES=mcp:read,mcp:write

# =============================================================================
# Storage
# =============================================================================

# Storage backend: sqlite (default) or json
ENGINEHAUS_STORAGE=sqlite

# Project auto-detection (set to override working directory detection)
# ENGINEHAUS_PROJECT=my-project

# =============================================================================
# Logging & Debug
# =============================================================================

# Enable verbose logging
ENGINEHAUS_VERBOSE=false

# Telemetry level: off, minimal, full (default: minimal)
ENGINEHAUS_TELEMETRY_LEVEL=minimal

# =============================================================================
# Project Root (optional)
# =============================================================================

# Override project root directory (default: current working directory)
# PROJECT_ROOT=/path/to/your/project
